# Prompit - Environment variable overrides for API keys
# Copy this file to .env and fill in your keys.
# These override the encrypted secrets.json for development.
# Format: PROMPIT_API_KEY_<INDEX>=your-api-key-here
# INDEX is zero-based, matching the model order in Settings.

# PROMPIT_API_KEY_0=sk-your-first-model-key
# PROMPIT_API_KEY_1=sk-your-second-model-key
