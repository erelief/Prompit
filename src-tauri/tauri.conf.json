{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "prompit",
  "version": "0.1.0",
  "identifier": "com.prompit.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:14227",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Translator",
        "width": 480,
        "height": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://github.com ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "shell": { "open": true },
    "updater": {
      "endpoints": [
        "https://github.com/erelief/Prompit/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0QTg3RjAyRjY3NTFCRDMKUldUVEczWDJBbitvdEhNVGxFNC80V0NNd3dZbjdwRC9tcFNsSncxUllwYzdJRStZeFpJVm9sbTMK"
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "createUpdaterArtifacts": true
  }
}
